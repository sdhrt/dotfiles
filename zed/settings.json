// documentation: https://zed.dev/docs/configuring-zed
{
  "theme": "Fleet Dark",
  "vim_mode": true,
  "buffer_font_family": "Maple Mono NF",
  "buffer_font_size": 16,
  "current_line_highlight": "line",
  "cursor_blink": false,
  "buffer_line_height": {
    "custom": 1.6
  },
  "git": {
    "inline_blame": {
      "enabled": false
    }
  },
  "terminal": {
    "font_size": 14,
    "font_family": "Maple Mono NF"
  },
  "telemetry": {
    "diagnostics": false,
    "metrics": false
  },
  "lsp": {
    "pyright": {
      "settings": {
        "python.analysis": {
          "diagnosticMode": "workspace",
          "typeCheckingMode": "strict"
        },
        "python": {
          "pythonPath": "/Users/sdhrt/Developer/coding/py/bin/python"
        }
      }
    },
    "vscode-html-language-server": {
      "settings": {
        "html": {
          "tagAutoclosing": true
        }
      }
    }
  },
  "language_overrides": {
    "Python": {
      "format_on_save": "on",
      "formatter": {
        "external": {
          "command": "bash",
          "arguments": [
            "-c",
            "ruff check --exit-zero --fix --unsafe-fixes --stdin-filename {buffer_path} | ruff format --stdin-filename {buffer_path}"
          ]
        }
      }
    }
  },
  "ssh_connections": [
    {
      "host": "nren123",
      "projects": [
        {
          "paths": [
            "/etc/nginx/sites-available"
          ]
        },
        {
          "paths": [
            "/home/siddhartha/PasswordManager"
          ]
        },
        {
          "paths": [
            "/home/siddhartha/venv"
          ]
        },
        {
          "paths": [
            "/home/user1/python_venv"
          ]
        }
      ]
    },
    {
      "host": "nren122",
      "projects": []
    },
    {
      "host": "nn",
      "projects": [
        {
          "paths": [
            "/home/user1/lora"
          ]
        },
        {
          "paths": [
            "/home/user1/lora/__pycache__"
          ]
        }
      ]
    }
  ]
}
